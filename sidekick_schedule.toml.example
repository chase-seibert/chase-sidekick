# Copy this example file to local/sidekick_schedule.toml and edit it for your own schedule.
#
# The cron entry should run at these three times every day. This file decides
# whether any Codex work should actually start at each slot.
#
# Slot times are PST.
# Valid day values are: mon, tue, wed, thu, fri, sat, sun, weekday, weekend, all.
# Use slots = ["morning"] for one slot.
# Use slots = ["morning", "evening"] to run the same task more than once per day.

[slots]
morning = "08:00"
midday = "13:00"
evening = "17:00"

[[tasks]]
name = "Weekly report"
enabled = true
days = ["fri"]
slots = ["morning"]
skill = "weekly-report"
prompt = """
Generate my weekly report for this week.
Save the final report under memory/.
"""

[[tasks]]
name = "Prep tomorrow meetings"
enabled = true
days = ["mon", "tue", "wed", "thu", "sun"]
slots = ["evening"]
skill = "prep-tomorrow-meetings"

[[tasks]]
name = "Daily meeting link check"
enabled = false
days = ["mon", "tue", "wed", "thu", "fri", "sat", "sun"]
slots = ["morning", "midday"]
prompt = """
Find meetings that need docs or links and prepare whatever is missing.
"""
